# E2E 测试环境变量配置示例
# 复制此文件为 .env.test.local 并根据实际情况修改

# Directus 测试实例 URL
TEST_BASE_URL=http://localhost:8055

# SQLite 数据库配置（测试模式使用 SQLite）
TEST_DB_FILE=./data/btdms_test.db
TEST_DB_DATABASE=btdms_test

# Directus 管理员配置（用于初始化）
ADMIN_EMAIL=admin@test.btdms.local
ADMIN_PASSWORD=admin_test_password

# 测试超时配置（毫秒）
TEST_TIMEOUT=30000
NAVIGATION_TIMEOUT=15000
ACTION_TIMEOUT=10000

# Playwright 配置
HEADED=false
DEBUG=false
RETRY=0

# 测试报告配置
REPORT_PORT=9323
