{
  "name": "btdms-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for BTDMS system using Playwright",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install --with-deps",
    "test:e2e:seed": "tsx scripts/seed-test-data.ts",
    "generate-mock-data": "python3 scripts/generate-mock-data.py",
    "verify:env": "bash ./scripts/verify-test-env.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3"
  }
}
